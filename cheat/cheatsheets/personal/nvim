# 插入模式的常用操作
<A-j/k>  # Move down/up

# 有提示的单字符
<space> z g " v [ ` ]  # leader, flod, go, jump, register, visual, jump

# Buffer manager
<ESC>L/H         # left, right buffer 
<leader>,        # choice buffers
<leader>bb       # choice recent buffer
<leader>fr       # choice all buffers
<leader>b_       # buffers action

# Diffview and gitsigns, 
<leader>gf  # DiffviewFileHistory
<leader>go  # DiffviewOpen
<leader>gq  # DiffviewClose
<leader>gb  # toggle blame for current line
<leader>gs  # Git status

# windows
<leader>w                   # 窗口操作如 split
<C-h/j/k/l>                 # 窗口跳转
<c-s-h/j/k/l>/<C-w>         # 窗口调整

# flit.nvim + leap.nvim
f/F/t/T{char}      # 单步跳, search char then jump
s/S/gs{char}{char} # 双步跳, search char char then jump
s/S<space><space>  # to jump to an empty line.


# text-object + mini.ai
vac  # around class
vaf  # around function
vai  # around indent
vao  # around Block, conditional, loop
vap  # around paragraph
vi?  # inside with prompt
va?
va(a( # 多次选择

# easy-align
ga=  # Around the 1st occurrences
ga2= # Around the 2nd occurrences
ga*= # Around all occurrences
ga**= # Left/Right alternating alignment around all occurrences
ga<Enter> # Switching between left/right/center alignment modes

# trouble
<leader>xx  # Document diagnostics

# marks
mm  # Toggle mark 'm'
m.  # next available mark
m/  # show all marks from the current buffer
m<space>  # Delete all marks from the current buffer

# gomove + swap
<A-S-h/j/k/l>   # move block or line to left,up,down,right
g>/<  # swap with right/left word
gS  # start swap mode
    - j/k  # choose item
    - h/l  # swap item
    - u/<C-r> # undo/redo
    - g/G  # group items/ UnGroup item
    - s/S  # sort items
    - r    # reverse
    - <ESC> # exit

# titlecase
gz/gzz # 句子变标题
gu/U/~  # 变小写 变大写 大小写互换

# Spectre
<leader>So  # Spectre Open
<leader>Sw  # Spectre search current word
<leader>Sf  # Spectre search current word in current file
?           # help, very important;)
# multi-edit
<C-N> + n/N/q/Q/<A->> + a/A/i/I  # 多处编辑

# symbols-outline
<leader>cs  # code symbols-outline
?           # show help

# projects
<leader>pp  # open projects list
<C-a>       # add this project to projects
<Esc>?      # change to normal model, then show its help

# telescope.nvim
<leader>ss                             # quickly jump to a function in the buffer
<leader>/  or <leader>sg               # search something in current project
<leader>sw                             # search current word in current project
<space><space> or <leader>ff           # search file in current project
<leader>sb                             # search something in current buffer
<leader>sm                             # search marks
<leader>s:/c/C                         # search executed command
<leader>cd or <leader>sd/D             # Line Diagnostics or search diagnostics
<leader>sk/o/h                         # search key mapping/options/help

# toggleterm.nvim  
<leader>/     # toggle float term
<leader>ft/l  # term bottom or right
<leader>fc/s  # term current line or selected
<leader>fT    # term in Tab

# flod, ufo
zR/r/M/m        # flod less or flod more 
za/A/o/O        # flod current cursor
zt/<enter>/z/b  # move this line to top/center,bottom

# LSP
gd/r/y/D/I          # goto Definition/reference/T[y]pe Definition/Declaration/Implementation
gld/r/y/D/I, gL     # goto Definition/reference/T[y]pe Definition/Declaration/Implementation preview(look),  then close this look

# markdown-preview
<leader>pm  # markdown-preview toggle
